<odoo>
    <data>
        <record id="group_user" model="res.groups">
            <field name="name">Role / User</field>
        </record>

        <record id="group_system" model="res.groups">
            <field name="name">Role / Administrator</field>
        </record>

        <record id="group_public" model="res.groups">
            <field name="name">Role / Public</field>
        </record>

        <record id="mass_mailing.res_groups_privilege_email_marketing" model="res.groups.privilege">
            <field name="name">Email Marketing</field>
        </record>

        <record id="mass_mailing.group_mass_mailing_user" model="res.groups">
            <field name="name">Email Marketing / User</field>
            <field name="privilege_id" ref="mass_mailing.res_groups_privilege_email_marketing"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>

    <data noupdate="1">
        <record id="module_category_hidden" model="ir.module.category">
            <field name="name">Hidden</field>
            <field name="sequence" eval="0"/>
        </record>

        <record id="module_category_administration" model="ir.module.category">
            <field name="name">Administration</field>
            <field name="sequence" eval="1"/>
        </record>

        <record id="module_category_user_type" model="ir.module.category">
            <field name="name">User Type</field>
            <field name="description">Helps identify the type of user.</field>
            <field name="sequence" eval="2"/>
        </record>

        <record id="USD" model="res.currency">
            <field name="name">USD</field>
            <field name="symbol">$</field>
            <field name="position">before</field>
            <field name="rounding" eval="0.01"/>
            <field name="decimal_places" eval="2"/>
            <field name="active" eval="True"/>
        </record>

        <record id="lang_en" model="res.lang">
            <field name="name">English (US)</field>
            <field name="code">en_US</field>
            <field name="iso_code">en</field>
            <field name="url_code">en</field>
            <field name="direction">ltr</field>
            <field name="active" eval="True"/>
        </record>

        <record id="us" model="res.country">
            <field name="name">United States</field>
            <field name="code">US</field>
            <field name="currency_id" ref="USD"/>
            <field name="active" eval="True"/>
        </record>

        <record id="main_company" model="res.company">
            <field name="name">My Company</field>
            <field name="active" eval="True"/>
            <field name="currency_id" ref="USD"/>
            <field name="country_id" ref="us"/>
        </record>

        <record id="model_res_company" model="ir.model">
            <field name="model">res.company</field>
            <field name="name">Company</field>
        </record>

        <record id="model_res_partner" model="ir.model">
            <field name="model">res.partner</field>
            <field name="name">Partner</field>
        </record>

        <record id="model_res_users" model="ir.model">
            <field name="model">res.users</field>
            <field name="name">User</field>
        </record>

        <record id="model_ir_cron" model="ir.model">
            <field name="model">ir.cron</field>
            <field name="name">Scheduled Action</field>
        </record>

        <record id="model_ir_autovacuum" model="ir.model">
            <field name="model">ir.autovacuum</field>
            <field name="name">Automatic Vacuum</field>
        </record>

        <record id="res_config_settings_view_form" model="ir.ui.view">
            <field name="name">res.config.settings.view.form</field>
            <field name="model">res.config.settings</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form>
                    <app name="general_settings" string="General Settings">
                        <block title="Users" name="users">
                            <setting string="Invite New Users" help="Enter an email">
                                <field name="active_user_count" readonly="1" string="1 Active User"/>
                            </setting>
                            <setting string="Manage Users" help="Create, activate, and review internal users.">
                                <field name="show_effect"/>
                            </setting>
                        </block>
                        <block title="Languages" name="languages">
                            <setting string="1 Language" help="Add Languages and Manage Languages.">
                                <field name="language_count" readonly="1"/>
                            </setting>
                        </block>
                        <block title="Companies" name="companies">
                            <setting string="My Company" help="Update Info">
                                <field name="company_name"/>
                            </setting>
                            <setting string="1 Company" help="Manage Companies">
                                <field name="company_count" readonly="1"/>
                            </setting>
                            <setting string="Document Layout" help="Choose the layout of your documents.">
                                <field name="external_report_layout_id"/>
                            </setting>
                        </block>
                    </app>
                    <app name="users_companies" string="Users &amp; Companies">
                        <block title="Users" name="users_companies_users">
                            <setting string="Users" help="Manage user access and preferences.">
                                <field name="active_user_count" readonly="1"/>
                            </setting>
                            <setting string="Companies" help="Manage companies available to users.">
                                <field name="company_count" readonly="1"/>
                            </setting>
                        </block>
                    </app>
                    <app name="translations" string="Translations">
                        <block title="Languages" name="translations_languages">
                            <setting string="Languages" help="Add languages and maintain translations.">
                                <field name="language_count" readonly="1"/>
                            </setting>
                        </block>
                    </app>
                    <app name="technical" string="Technical">
                        <block title="Technical" name="technical">
                            <setting string="Import &amp; Export" help="Allow importing data from files.">
                                <field name="module_base_import"/>
                            </setting>
                            <setting string="OAuth Authentication" help="Enable OAuth sign-in providers.">
                                <field name="module_auth_oauth"/>
                            </setting>
                            <setting string="LDAP Authentication" help="Enable LDAP sign-in.">
                                <field name="module_auth_ldap"/>
                            </setting>
                        </block>
                    </app>
                </form>
            </field>
        </record>

        <record id="action_currency_form" model="ir.actions.act_window">
            <field name="name">Currencies</field>
            <field name="res_model">res.currency</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="web.action_base_document_layout_configurator" model="ir.actions.act_window">
            <field name="name">Configure Document Layout</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="res_config_settings_view_form"/>
            <field name="target">new</field>
        </record>

        <record id="module_base" model="ir.module.module">
            <field name="name">base</field>
            <field name="state">installed</field>
        </record>

        <record id="config_platform_bootstrap" model="ir.config_parameter">
            <field name="key">gorp.base.bootstrap</field>
            <field name="value">1</field>
        </record>

        <record id="config_mass_mailing_reports" model="ir.config_parameter">
            <field name="key">mass_mailing.mass_mailing_reports</field>
            <field name="value">True</field>
        </record>
    </data>
</odoo>
