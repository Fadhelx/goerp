<odoo>
    <data noupdate="1">
        <record id="user_root" model="res.users">
            <field name="login">__system__</field>
            <field name="name">System</field>
            <field name="email">odoobot@example.com</field>
            <field name="signature" type="html"><div>System</div></field>
            <field name="active" eval="False"/>
            <field name="company_id" ref="main_company"/>
            <field name="company_ids" eval="[(4, ref('main_company'))]"/>
            <field name="group_ids" eval="[(4, ref('group_system'))]"/>
            <field name="partner_id" ref="main_partner"/>
        </record>

        <record id="user_admin" model="res.users">
            <field name="login">admin</field>
            <field name="password">admin</field>
            <field name="name">Administrator</field>
            <field name="signature" type="html"><div>Administrator</div></field>
            <field name="active" eval="True"/>
            <field name="company_id" ref="main_company"/>
            <field name="company_ids" eval="[(4, ref('main_company'))]"/>
            <field name="group_ids" eval="[(4, ref('group_system'))]"/>
            <field name="partner_id" ref="main_partner"/>
        </record>

        <record id="public_partner" model="res.partner">
            <field name="name">Public User</field>
            <field name="active" eval="False"/>
        </record>

        <record id="public_user" model="res.users">
            <field name="login">public</field>
            <field name="name">Public User</field>
            <field name="active" eval="False"/>
            <field name="image_1920" type="base64" file="base/static/img/public_user-image.png"/>
            <field name="company_id" ref="main_company"/>
            <field name="company_ids" eval="[(4, ref('main_company'))]"/>
            <field name="group_ids" eval="[(4, ref('group_public'))]"/>
            <field name="partner_id" ref="public_partner"/>
        </record>

        <record id="user_admin_settings" model="res.users.settings">
            <field name="user_id" ref="base.user_admin"/>
        </record>
    </data>
</odoo>
