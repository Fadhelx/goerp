<odoo>
  <data noupdate="1">
    <record id="ai_topic_general" model="ai.topic">
      <field name="name">General Assistance</field>
      <field name="description">General ERP assistance.</field>
      <field name="instructions">Use only available context, tools, and permitted records.</field>
      <field name="active" eval="True"/>
      <field name="company_id" ref="base.main_company"/>
    </record>
    <record id="ai_topic_natural_language_query" model="ai.topic">
      <field name="name">Natural Language Query</field>
      <field name="description">Navigate menus and adjust search/report views from natural language requests.</field>
      <field name="instructions">Use menu metadata before opening or adjusting views. Validate the target model and view type.</field>
      <field name="tool_ids" eval="[(6, 0, [ref('ir_actions_server_get_fields'), ref('ir_actions_server_get_menu_details'), ref('ir_actions_server_compute_report_measures'), ref('ir_actions_server_open_menu_list'), ref('ir_actions_server_open_menu_kanban'), ref('ir_actions_server_open_menu_pivot'), ref('ir_actions_server_open_menu_graph'), ref('ir_actions_server_adjust_search')])]"/>
      <field name="active" eval="True"/>
      <field name="company_id" ref="base.main_company"/>
    </record>
    <record id="ai_topic_information_retrieval_query" model="ai.topic">
      <field name="name">Information Retrieval Query</field>
      <field name="description">Inspect allowed models and retrieve records or grouped facts.</field>
      <field name="instructions">Use model fields before searching. Return only data accessible through permitted tools.</field>
      <field name="tool_ids" eval="[(6, 0, [ref('ir_actions_server_get_fields'), ref('ir_actions_server_search'), ref('ir_actions_server_read_group')])]"/>
      <field name="active" eval="True"/>
      <field name="company_id" ref="base.main_company"/>
    </record>
  </data>
</odoo>
