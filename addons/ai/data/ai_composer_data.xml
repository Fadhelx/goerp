<odoo>
  <data noupdate="1">
    <record id="ai_composer_mail" model="ai.composer">
      <field name="name">Write an email</field>
      <field name="interface_key">mail_composer</field>
      <field name="ai_agent" ref="ai_default_agent"/>
      <field name="default_prompt">Draft a concise professional message using the selected context.</field>
      <field name="is_system_default" eval="True"/>
      <field name="active" eval="True"/>
    </record>
    <record id="ai_prompt_summarize" model="ai.prompt.button">
      <field name="name">Summarize</field>
      <field name="prompt">Summarize the current record.</field>
      <field name="model_name">mail.thread</field>
      <field name="use_in_ai" eval="True"/>
      <field name="sequence" eval="10"/>
      <field name="composer_id" ref="ai_composer_mail"/>
      <field name="active" eval="True"/>
      <field name="company_id" ref="base.main_company"/>
    </record>
    <record id="ai_prompt_write_followup_composer" model="ai.prompt.button">
      <field name="name">Write a followup answer</field>
      <field name="prompt">Draft a followup answer using the current conversation.</field>
      <field name="sequence" eval="20"/>
      <field name="active" eval="True"/>
      <field name="company_id" ref="base.main_company"/>
    </record>
    <record id="ai_prompt_summarize_chatter" model="ai.prompt.button">
      <field name="name">Summarize the chatter conversation</field>
      <field name="prompt">Summarize the chatter conversation.</field>
      <field name="sequence" eval="10"/>
      <field name="active" eval="True"/>
      <field name="company_id" ref="base.main_company"/>
    </record>
    <record id="ai_prompt_write_followup_chatter" model="ai.prompt.button">
      <field name="name">Write a followup answer</field>
      <field name="prompt">Write a followup answer for the chatter conversation.</field>
      <field name="sequence" eval="20"/>
      <field name="active" eval="True"/>
      <field name="company_id" ref="base.main_company"/>
    </record>
    <record id="ai_prompt_open_records" model="ai.prompt.button">
      <field name="name">Show records matching my request</field>
      <field name="prompt">Open the best matching Odoo view and apply the requested search.</field>
      <field name="sequence" eval="30"/>
      <field name="active" eval="True"/>
      <field name="company_id" ref="base.main_company"/>
    </record>
    <record id="ai_mail_composer" model="ai.composer">
      <field name="name">Mail/Note Composer</field>
      <field name="interface_key">mail_composer</field>
      <field name="ai_agent" ref="ai_default_agent"/>
      <field name="default_prompt">Draft message bodies only. Do not add a subject or signature unless requested.</field>
      <field name="available_prompts" eval="[(4, ref('ai_prompt_write_followup_composer'))]"/>
      <field name="is_system_default" eval="True"/>
      <field name="active" eval="True"/>
    </record>
    <record id="ai_chatter_helper" model="ai.composer">
      <field name="name">Chatter Helper</field>
      <field name="interface_key">chatter_ai_button</field>
      <field name="ai_agent" ref="ai_default_agent"/>
      <field name="default_prompt">Assist with the record chatter. Write only content that can be inserted into the conversation.</field>
      <field name="available_prompts" eval="[(4, ref('ai_prompt_summarize_chatter')), (4, ref('ai_prompt_write_followup_chatter'))]"/>
      <field name="is_system_default" eval="True"/>
      <field name="active" eval="True"/>
    </record>
    <record id="ai_systray_action" model="ai.composer">
      <field name="name">Ask AI</field>
      <field name="interface_key">systray_ai_button</field>
      <field name="ai_agent" ref="ai_default_agent"/>
      <field name="available_prompts" eval="[(4, ref('ai_prompt_summarize')), (4, ref('ai_prompt_open_records'))]"/>
      <field name="is_system_default" eval="True"/>
      <field name="active" eval="True"/>
    </record>
  </data>
</odoo>
