<odoo>
  <data noupdate="1">
    <record id="button_delegation_confirm" model="approval.buttons">
      <field name="settings_id" ref="approval_settings_delegation"/>
      <field name="config_id" ref="approval_config_delegation"/>
      <field name="model">delegation</field>
      <field name="model_id" ref="model_delegation"/>
      <field name="sequence" eval="10"/>
      <field name="active" eval="True"/>
      <field name="name">Confirm</field>
      <field name="action_type">approve</field>
      <field name="state_value">draft</field>
      <field name="next_state">confirmed</field>
      <field name="visible_to">group</field>
      <field name="group_ids" eval="[(4, ref('group_delegation_manager'))]"/>
      <field name="email_template_id" ref="mail_template_delegation_assigned"/>
      <field name="button_class">primary</field>
    </record>
    <record id="button_delegation_revoke" model="approval.buttons">
      <field name="settings_id" ref="approval_settings_delegation"/>
      <field name="config_id" ref="approval_config_delegation"/>
      <field name="model">delegation</field>
      <field name="model_id" ref="model_delegation"/>
      <field name="sequence" eval="20"/>
      <field name="active" eval="True"/>
      <field name="name">Revoke</field>
      <field name="action_type">reject</field>
      <field name="state_value">confirmed</field>
      <field name="next_state">revoked</field>
      <field name="visible_to">group</field>
      <field name="group_ids" eval="[(4, ref('group_delegation_manager'))]"/>
      <field name="email_template_id" ref="mail_template_delegation_revoked"/>
      <field name="comment_required" eval="True"/>
      <field name="button_class">secondary</field>
    </record>
    <record id="button_delegation_expire" model="approval.buttons">
      <field name="settings_id" ref="approval_settings_delegation"/>
      <field name="config_id" ref="approval_config_delegation"/>
      <field name="model">delegation</field>
      <field name="model_id" ref="model_delegation"/>
      <field name="sequence" eval="30"/>
      <field name="active" eval="True"/>
      <field name="name">Mark Expired</field>
      <field name="action_type">method</field>
      <field name="state_value">confirmed</field>
      <field name="next_state">expired</field>
      <field name="method">expire_delegation</field>
      <field name="email_template_id" ref="mail_template_delegation_expired"/>
      <field name="button_class">secondary</field>
    </record>
  </data>
</odoo>
