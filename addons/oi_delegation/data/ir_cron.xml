<odoo>
  <data noupdate="1">
    <record id="cron_clear_access_cache" model="ir.cron">
      <field name="name">Clear Access Cache</field>
      <field name="user_id" ref="base.user_root"/>
      <field name="active" eval="True"/>
      <field name="interval_number" eval="1"/>
      <field name="interval_type">days</field>
      <field name="model_id" ref="model_delegation"/>
      <field name="state">code</field>
      <field name="code">model._clear_access_cache()</field>
      <field name="nextcall" eval="datetime.today() + relativedelta(days=1,hour=0, second=0, minute=0)"/>
      <field name="failure_count" eval="0"/>
      <field name="action_name">delegation_clear_expired_access</field>
    </record>
  </data>
</odoo>
