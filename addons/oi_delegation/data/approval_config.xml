<odoo>
  <data noupdate="1">
    <record id="approval_settings_delegation" model="approval.settings">
      <field name="name">Delegation Approval</field>
      <field name="model">delegation</field>
      <field name="model_id" ref="model_delegation"/>
      <field name="active" eval="True"/>
      <field name="state_field">state</field>
      <field name="draft_state">draft</field>
      <field name="approved_state">confirmed</field>
      <field name="rejected_state">revoked</field>
      <field name="cancelled_state">cancelled</field>
    </record>
    <record id="approval_config_delegation" model="approval.config">
      <field name="name">Delegation Approval Config</field>
      <field name="model">delegation</field>
      <field name="settings_id" ref="approval_settings_delegation"/>
      <field name="active" eval="True"/>
    </record>
    <record id="approval_state_delegation_draft" model="approval.settings.state">
      <field name="settings_id" ref="approval_settings_delegation"/>
      <field name="value">draft</field>
      <field name="name">Draft</field>
      <field name="sequence" eval="10"/>
      <field name="kind">draft</field>
    </record>
    <record id="approval_state_delegation_confirmed" model="approval.settings.state">
      <field name="settings_id" ref="approval_settings_delegation"/>
      <field name="value">confirmed</field>
      <field name="name">Confirmed</field>
      <field name="sequence" eval="20"/>
      <field name="kind">approved</field>
      <field name="group_ids" eval="[(4, ref('group_delegation_manager'))]"/>
    </record>
    <record id="approval_state_delegation_revoked" model="approval.settings.state">
      <field name="settings_id" ref="approval_settings_delegation"/>
      <field name="value">revoked</field>
      <field name="name">Revoked</field>
      <field name="sequence" eval="30"/>
      <field name="kind">rejected</field>
    </record>
  </data>
</odoo>
