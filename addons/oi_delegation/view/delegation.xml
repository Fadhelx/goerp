<odoo>
  <record id="view_delegation_form_list" model="ir.ui.view">
    <field name="name">delegation.list</field>
    <field name="model">delegation</field>
    <field name="arch" type="xml">
      <list>
        <field name="name"/>
        <field name="employee_id" widget="many2one_avatar_employee"/>
        <field name="date_from"/>
        <field name="date_to"/>
        <field name="state" widget="badge" decoration-success="state =='approved'" decoration-info="state =='draft'" decoration-warning="waiting_approval"/>
        <field name="isactive"/>
        <field name="waiting_approval" column_invisible="1"/>
      </list>
    </field>
  </record>

  <record id="view_delegation_form_search" model="ir.ui.view">
    <field name="name">Delegation Search</field>
    <field name="model">delegation</field>
    <field name="arch" type="xml">
      <search>
        <field name="name"/>
        <field name="employee_id"/>
        <separator/>
        <filter string="Active" name="active" domain="[('state','=','confirmed'), ('date_from','&gt;=', current_date), ('date_to','&lt;=', current_date)]"/>
        <filter string="Draft" name="draft" domain="[('state','=','draft')]"/>
        <filter string="Confirm" name="confirm" domain="[('state','=','confirmed')]"/>
        <group expand="0" string="Group By">
          <filter string="Status" name="status" context="{'group_by':'state'}"/>
          <filter string="Employee" name="employee" context="{'group_by':'employee_id'}"/>
        </group>
      </search>
    </field>
  </record>

  <record id="view_delegation_form" model="ir.ui.view">
    <field name="name">delegation.form</field>
    <field name="model">delegation</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_revoked" type="object" string="Revoke" invisible="state not in ['confirmed']" confirm="Revoke ?"/>
          <field name="state" widget="statusbar"/>
        </header>
        <sheet>
          <div class="oe_button_box" name="button_box"/>
          <div class="oe_title">
            <h1>
              <field name="name" readonly="1"/>
            </h1>
          </div>
          <group>
            <group>
              <field name="employee_id" groups="base.group_system" widget="many2one_avatar_employee" domain="[('user_id.active','=', True)]" readonly="state!='draft'"/>
              <field name="employee_id" groups="!base.group_system" widget="many2one_avatar_employee" readonly="1"/>
              <field name="user_id" invisible="1"/>
              <field name="date_from" readonly="state != 'draft'"/>
              <field name="date_to" readonly="state != 'draft'"/>
            </group>
            <group>
              <field name="one_employee" readonly="state != 'draft'"/>
              <field name="delegateTo_employee_id" widget="many2one_avatar_employee" domain="[('id','!=',employee_id), ('user_id','!=', False), '|', ('parent_id','=', employee_id), ('parent_id.child_ids','=',employee_id)]" options="{'no_create': True}" required="one_employee" invisible="not one_employee" readonly="state != 'draft'"/>
              <field name="department_ids" widget="many2many_tags" options="{'no_create' : 1}" domain="['|', ('manager_id','=', employee_id), ('member_ids','child_of', [employee_id])]" readonly="state != 'draft'"/>
            </group>
          </group>
          <group string="Assigned Roles">
            <field name="lines" nolabel="1" colspan="2" readonly="state != 'draft'">
              <list editable="bottom" delete="false" create="false">
                <field name="delegator_id" column_invisible="1"/>
                <field name="group_id" readonly="1" force_save="1"/>
                <field name="employee_id" widget="many2one_avatar_employee" domain="[('user_id','!=', False), ('id','!=',delegator_id), '|', ('parent_id','=', delegator_id), ('parent_id.child_ids','=',delegator_id)]" options="{'no_create': True}" readonly="one_employee"/>
                <field name="one_employee" column_invisible="1"/>
              </list>
            </field>
          </group>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>
</odoo>
