<odoo>
  <record id="group_workflow_advance_user" model="res.groups">
    <field name="name">Workflow Advance / User</field>
    <field name="implied_ids" eval="[(4, ref('oi_workflow.group_workflow_user'))]"/>
  </record>
  <record id="group_workflow_advance_manager" model="res.groups">
    <field name="name">Workflow Advance / Manager</field>
    <field name="implied_ids" eval="[(4, ref('group_workflow_advance_user')), (4, ref('oi_workflow.group_workflow_manager'))]"/>
  </record>
  <record id="group_workflow_advance_admin" model="res.groups">
    <field name="name">Workflow Advance / Administrator</field>
    <field name="implied_ids" eval="[(4, ref('group_workflow_advance_manager')), (4, ref('oi_workflow.group_workflow_admin'))]"/>
  </record>
  <record id="model_workflow" model="ir.model">
    <field name="model">workflow</field>
    <field name="name">Workflow</field>
  </record>
  <record id="model_workflow_node" model="ir.model">
    <field name="model">workflow.node</field>
    <field name="name">Workflow Node</field>
  </record>
  <record id="model_workflow_transition" model="ir.model">
    <field name="model">workflow.transition</field>
    <field name="name">Workflow Transition</field>
  </record>
  <record id="model_workflow_node_action" model="ir.model">
    <field name="model">workflow.node.action</field>
    <field name="name">Workflow Node Action</field>
  </record>
  <record id="model_workflow_process" model="ir.model">
    <field name="model">workflow.process</field>
    <field name="name">Workflow Process</field>
  </record>
  <record id="model_workflow_process_wizard" model="ir.model">
    <field name="model">workflow.process.wizard</field>
    <field name="name">Workflow Process Wizard</field>
  </record>
  <record id="rule_workflow_company" model="ir.rule">
    <field name="name">Workflow company access</field>
    <field name="model_id" ref="model_workflow"/>
    <field name="domain_force">["|",["company_id","=",false],["company_id","in","user.company_ids"]]</field>
    <field name="global" eval="True"/>
    <field name="active" eval="True"/>
    <field name="perm_read" eval="True"/>
    <field name="perm_write" eval="True"/>
    <field name="perm_create" eval="True"/>
    <field name="perm_unlink" eval="True"/>
  </record>
</odoo>
