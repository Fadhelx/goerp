<odoo>
  <data noupdate="1">
    <record id="mail_template_approval_request" model="mail.template">
      <field name="name">Approval Request</field>
      <field name="model">approval.record</field>
      <field name="subject">Approval requested</field>
      <field name="body_html">&lt;p&gt;A record is waiting for approval.&lt;/p&gt;</field>
      <field name="active" eval="True"/>
    </record>
    <record id="mail_template_approval_complete" model="mail.template">
      <field name="name">Approval Complete</field>
      <field name="model">approval.record</field>
      <field name="subject">Approval completed</field>
      <field name="body_html">&lt;p&gt;The approval process has completed.&lt;/p&gt;</field>
      <field name="active" eval="True"/>
    </record>
  </data>
</odoo>
