<odoo>
  <data noupdate="1">
    <record id="approval_settings_cancellation_record" model="approval.settings">
      <field name="name">Cancellation Workflow</field>
      <field name="model">cancellation.record</field>
      <field name="model_id" ref="model_cancellation_record"/>
      <field name="sequence" eval="10"/>
      <field name="active" eval="True"/>
      <field name="state_field">state</field>
      <field name="draft_state">draft</field>
      <field name="approved_state">approved</field>
      <field name="rejected_state">rejected</field>
      <field name="cancelled_state">cancelled</field>
    </record>
  </data>
</odoo>
