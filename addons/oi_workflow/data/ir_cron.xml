<odoo>
  <data noupdate="1">
    <record id="cron_update_approval_activity" model="ir.cron">
      <field name="name">Workflow: Update approval activities</field>
      <field name="active" eval="True"/>
      <field name="interval_number" eval="1"/>
      <field name="interval_type">days</field>
      <field name="model_id" ref="model_approval_settings"/>
      <field name="state">code</field>
      <field name="code">model.update_pending_activities()</field>
    </record>
  </data>
</odoo>
