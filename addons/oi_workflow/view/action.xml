<odoo>
  <record id="act_approval_settings" model="ir.actions.act_window">
    <field name="name">Approval Settings</field>
    <field name="res_model">approval.settings</field>
    <field name="view_mode">list,form</field>
  </record>
  <record id="act_approval_config" model="ir.actions.act_window">
    <field name="name">Approval Configurations</field>
    <field name="res_model">approval.config</field>
    <field name="view_mode">list,form</field>
  </record>
  <record id="act_approval_buttons" model="ir.actions.act_window">
    <field name="name">Approval Buttons</field>
    <field name="res_model">approval.buttons</field>
    <field name="view_mode">list,form</field>
  </record>
  <record id="act_approval_logs" model="ir.actions.act_window">
    <field name="name">Approval Logs</field>
    <field name="res_model">approval.log</field>
    <field name="view_mode">list,form</field>
  </record>
  <record id="act_cancellation_records" model="ir.actions.act_window">
    <field name="name">Cancellation Records</field>
    <field name="res_model">cancellation.record</field>
    <field name="view_mode">list,form</field>
  </record>
  <record id="act_approval_state_update" model="ir.actions.act_window">
    <field name="name">Approval State Update</field>
    <field name="res_model">approval.state.update</field>
    <field name="view_mode">form</field>
  </record>
  <record id="act_model_expression_editor" model="ir.actions.act_window">
    <field name="name">Model Expression Editor</field>
    <field name="res_model">model.expression.editor</field>
    <field name="view_mode">form</field>
  </record>
</odoo>
