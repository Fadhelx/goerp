    <field name="name">Approval Settings</field>
  </record>
  <record id="model_approval_settings_state" model="ir.model">
    <field name="model">approval.settings.state</field>
    <field name="name">Approval Settings State</field>
  </record>
  <record id="model_approval_config" model="ir.model">
    <field name="model">approval.config</field>
    <field name="name">Approval Config</field>
  </record>
  <record id="model_approval_buttons" model="ir.model">
    <field name="model">approval.buttons</field>
    <field name="name">Approval Buttons</field>
  </record>
  <record id="model_approval_automation" model="ir.model">
    <field name="model">approval.automation</field>
    <field name="name">Approval Automation</field>
  </record>
  <record id="model_approval_escalation" model="ir.model">
    <field name="model">approval.escalation</field>
