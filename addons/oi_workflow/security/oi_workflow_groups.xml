<odoo>
  <record id="group_workflow_user" model="res.groups">
    <field name="name">Workflow / User</field>
  </record>
  <record id="group_workflow_manager" model="res.groups">
    <field name="name">Workflow / Manager</field>
    <field name="implied_ids" eval="[(4, ref('group_workflow_user'))]"/>
  </record>
  <record id="group_workflow_admin" model="res.groups">
    <field name="name">Workflow / Administrator</field>
    <field name="implied_ids" eval="[(4, ref('group_workflow_manager'))]"/>
  </record>
  <record id="model_approval_settings" model="ir.model">
