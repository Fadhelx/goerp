<odoo>
  <data>
    <record id="analytic.view_account_analytic_account_form" model="ir.ui.view">
      <field name="name">account.analytic.account.form</field>
      <field name="model">account.analytic.account</field>
      <field name="type">form</field>
      <field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="code"/><field name="plan_id"/><field name="partner_id"/></group></sheet></form></field>
    </record>

    <record id="analytic.view_account_analytic_account_list" model="ir.ui.view">
      <field name="name">account.analytic.account.list</field>
      <field name="model">account.analytic.account</field>
      <field name="type">list</field>
      <field name="arch" type="xml"><list><field name="name"/><field name="code"/><field name="plan_id"/><field name="balance"/></list></field>
    </record>

    <record id="analytic.view_account_analytic_line_form" model="ir.ui.view">
      <field name="name">account.analytic.line.form</field>
      <field name="model">account.analytic.line</field>
      <field name="type">form</field>
      <field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="account_id"/><field name="product_id"/><field name="amount"/></group></sheet></form></field>
    </record>

    <record id="analytic.view_account_analytic_line_tree" model="ir.ui.view">
      <field name="name">account.analytic.line.list</field>
      <field name="model">account.analytic.line</field>
      <field name="type">list</field>
      <field name="arch" type="xml"><list><field name="date"/><field name="name"/><field name="account_id"/><field name="product_id"/><field name="amount"/></list></field>
    </record>

    <record id="analytic.view_account_analytic_line_filter" model="ir.ui.view">
      <field name="name">account.analytic.line.search</field>
      <field name="model">account.analytic.line</field>
      <field name="type">search</field>
      <field name="arch" type="xml"><search><field name="name"/><field name="account_id"/><field name="product_id"/></search></field>
    </record>

    <record id="analytic.view_account_analytic_line_pivot" model="ir.ui.view">
      <field name="name">account.analytic.line.pivot</field>
      <field name="model">account.analytic.line</field>
      <field name="type">pivot</field>
      <field name="arch" type="xml"><pivot><field name="account_id" type="row"/><field name="amount" type="measure"/></pivot></field>
    </record>

    <record id="analytic.account_analytic_plan_form_view" model="ir.ui.view">
      <field name="name">account.analytic.plan.form</field>
      <field name="model">account.analytic.plan</field>
      <field name="type">form</field>
      <field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="default_applicability"/><field name="applicability_ids"/></group></sheet></form></field>
    </record>

    <record id="analytic.account_analytic_distribution_model_tree_view" model="ir.ui.view">
      <field name="name">account.analytic.distribution.model.list</field>
      <field name="model">account.analytic.distribution.model</field>
      <field name="type">list</field>
      <field name="arch" type="xml"><list><field name="name"/><field name="account_prefix"/><field name="product_id"/><field name="product_categ_id"/><field name="analytic_distribution"/></list></field>
    </record>

    <record id="analytic.account_analytic_distribution_model_form_view" model="ir.ui.view">
      <field name="name">account.analytic.distribution.model.form</field>
      <field name="model">account.analytic.distribution.model</field>
      <field name="type">form</field>
      <field name="arch" type="xml"><form><sheet><group><field name="name"/><field name="account_prefix"/><field name="product_id"/><field name="product_categ_id"/><field name="analytic_distribution"/></group></sheet></form></field>
    </record>

    <record id="analytic.account_analytic_line_action_entries" model="ir.actions.act_window">
      <field name="name">Analytic Items</field>
      <field name="res_model">account.analytic.line</field>
      <field name="view_mode">list,form,pivot</field>
      <field name="view_id" ref="analytic.view_account_analytic_line_tree"/>
    </record>

    <record id="analytic.action_account_analytic_account_form" model="ir.actions.act_window">
      <field name="name">Analytic Accounts</field>
      <field name="res_model">account.analytic.account</field>
      <field name="view_mode">list,form</field>
      <field name="view_id" ref="analytic.view_account_analytic_account_list"/>
    </record>

    <record id="analytic.account_analytic_plan_action" model="ir.actions.act_window">
      <field name="name">Analytic Plans</field>
      <field name="res_model">account.analytic.plan</field>
      <field name="view_mode">list,form</field>
      <field name="view_id" ref="analytic.account_analytic_plan_form_view"/>
    </record>

    <record id="analytic.action_analytic_distribution_model" model="ir.actions.act_window">
      <field name="name">Analytic Distribution Models</field>
      <field name="res_model">account.analytic.distribution.model</field>
      <field name="view_mode">list,form</field>
      <field name="view_id" ref="analytic.account_analytic_distribution_model_tree_view"/>
    </record>
  </data>
</odoo>
