<odoo>
  <data noupdate="1">
    <record id="view_account_payment_form" model="ir.ui.view">
      <field name="name">account.payment.form</field>
      <field name="model">account.payment</field>
      <field name="arch">&lt;form&gt;&lt;field name="name"/&gt;&lt;field name="amount"/&gt;&lt;field name="move_id"/&gt;&lt;field name="state"/&gt;&lt;field name="is_reconciled"/&gt;&lt;field name="is_matched"/&gt;&lt;field name="is_sent"/&gt;&lt;field name="invoice_ids"/&gt;&lt;field name="reconciled_invoice_ids"/&gt;&lt;field name="reconciled_bill_ids"/&gt;&lt;field name="need_cancel_request"/&gt;&lt;/form&gt;</field>
    </record>
    <record id="view_account_payment_list" model="ir.ui.view">
      <field name="name">account.payment.list</field>
      <field name="model">account.payment</field>
      <field name="arch">&lt;list&gt;&lt;field name="name"/&gt;&lt;field name="amount"/&gt;&lt;/list&gt;</field>
    </record>
    <record id="action_account_payments" model="ir.actions.act_window">
      <field name="name">Payments</field>
      <field name="res_model">account.payment</field>
      <field name="view_mode">list,form</field>
    </record>
    <record id="action_account_confirm_payments" model="ir.actions.server">
      <field name="name">Confirm Payments</field>
      <field name="model_name">account.payment</field>
      <field name="state">code</field>
      <field name="active" eval="True"/>
      <field name="code">model.action_post()</field>
    </record>
  </data>
</odoo>
