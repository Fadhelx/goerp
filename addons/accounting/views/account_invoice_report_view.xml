<odoo>
  <data noupdate="1">
    <record id="view_account_invoice_report_tree" model="ir.ui.view">
      <field name="name">account.invoice.report.list</field>
      <field name="model">account.invoice.report</field>
      <field name="arch">&lt;list&gt;&lt;field name="invoice_date"/&gt;&lt;field name="partner_id"/&gt;&lt;field name="move_type"/&gt;&lt;field name="state"/&gt;&lt;field name="price_subtotal"/&gt;&lt;field name="price_total"/&gt;&lt;/list&gt;</field>
    </record>
    <record id="view_account_invoice_report_search" model="ir.ui.view">
      <field name="name">account.invoice.report.search</field>
      <field name="model">account.invoice.report</field>
      <field name="arch">&lt;search&gt;&lt;field name="partner_id"/&gt;&lt;field name="journal_id"/&gt;&lt;field name="company_id"/&gt;&lt;/search&gt;</field>
    </record>
    <record id="action_account_invoice_report_all" model="ir.actions.act_window">
      <field name="name">Invoice Analysis</field>
      <field name="res_model">account.invoice.report</field>
      <field name="view_mode">list</field>
      <field name="view_id" ref="view_account_invoice_report_tree"/>
    </record>
  </data>
</odoo>
