<odoo>
  <data noupdate="1">
    <record id="view_account_journal_tree" model="ir.ui.view">
      <field name="name">account.journal.list</field>
      <field name="model">account.journal</field>
      <field name="arch">&lt;list&gt;&lt;field name="code"/&gt;&lt;field name="name"/&gt;&lt;/list&gt;</field>
    </record>
    <record id="view_account_journal_form" model="ir.ui.view">
      <field name="name">account.journal.form</field>
      <field name="model">account.journal</field>
      <field name="arch">&lt;form&gt;&lt;field name="code"/&gt;&lt;field name="type"/&gt;&lt;/form&gt;</field>
    </record>
    <record id="action_account_journal_form" model="ir.actions.act_window">
      <field name="name">Journals</field>
      <field name="res_model">account.journal</field>
      <field name="view_mode">list,form</field>
    </record>
    <record id="view_account_journal_group_tree" model="ir.ui.view">
      <field name="name">account.journal.group.list</field>
      <field name="model">account.journal.group</field>
      <field name="arch">&lt;list&gt;&lt;field name="sequence"/&gt;&lt;field name="name"/&gt;&lt;field name="company_id"/&gt;&lt;/list&gt;</field>
    </record>
    <record id="view_account_journal_group_form" model="ir.ui.view">
      <field name="name">account.journal.group.form</field>
      <field name="model">account.journal.group</field>
      <field name="arch">&lt;form&gt;&lt;field name="name"/&gt;&lt;field name="company_id"/&gt;&lt;field name="excluded_journal_ids"/&gt;&lt;/form&gt;</field>
    </record>
    <record id="action_account_journal_group" model="ir.actions.act_window">
      <field name="name">Journal Groups</field>
      <field name="res_model">account.journal.group</field>
      <field name="view_mode">list,form</field>
      <field name="view_id" ref="view_account_journal_group_tree"/>
    </record>
  </data>
</odoo>
