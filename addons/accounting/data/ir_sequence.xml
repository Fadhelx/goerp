<odoo>
  <data noupdate="1">
    <record id="seq_account_move" model="ir.sequence">
      <field name="name">Journal Entry</field>
      <field name="code">account.move</field>
      <field name="prefix">MISC/</field>
      <field name="padding" eval="4"/>
      <field name="number_next" eval="1"/>
      <field name="number_increment" eval="1"/>
      <field name="active" eval="True"/>
      <field name="implementation">standard</field>
    </record>
    <record id="seq_account_payment" model="ir.sequence">
      <field name="name">Payment</field>
      <field name="code">account.payment</field>
      <field name="prefix">PAY/</field>
      <field name="padding" eval="5"/>
      <field name="number_next" eval="1"/>
      <field name="number_increment" eval="1"/>
      <field name="active" eval="True"/>
      <field name="implementation">standard</field>
    </record>
  </data>
</odoo>
