<odoo>
  <data noupdate="1">
    <record id="uom.group_uom" model="res.groups">
      <field name="name">Manage Units of Measure</field>
      <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="uom.product_uom_categ_unit" model="uom.category">
      <field name="name">Unit</field>
    </record>

    <record id="uom.product_uom_unit" model="uom.uom">
      <field name="name">Units</field>
      <field name="category_id" ref="uom.product_uom_categ_unit"/>
      <field name="uom_type">reference</field>
      <field name="factor" eval="1.0"/>
      <field name="factor_inv" eval="1.0"/>
      <field name="rounding" eval="0.01"/>
      <field name="active" eval="True"/>
    </record>

    <record id="product.product_category_all" model="product.category">
      <field name="name">All</field>
      <field name="complete_name">All</field>
      <field name="parent_path">/</field>
    </record>

    <record id="product.product_product_1_product_template" model="product.template">
      <field name="name">Generic Product</field>
      <field name="type">consu</field>
      <field name="detailed_type">consu</field>
      <field name="categ_id" ref="product.product_category_all"/>
      <field name="uom_id" ref="uom.product_uom_unit"/>
      <field name="uom_po_id" ref="uom.product_uom_unit"/>
      <field name="list_price" eval="1.0"/>
      <field name="standard_price" eval="0.0"/>
      <field name="sale_ok" eval="True"/>
      <field name="purchase_ok" eval="True"/>
      <field name="active" eval="True"/>
      <field name="taxes_id" eval="[Command.link(ref('account.account_tax_sale_15'))]"/>
      <field name="supplier_taxes_id" eval="[Command.link(ref('account.account_tax_purchase_15'))]"/>
    </record>

    <record id="product.product_product_1" model="product.product">
      <field name="name">Generic Product</field>
      <field name="product_tmpl_id" ref="product.product_product_1_product_template"/>
      <field name="default_code">GEN</field>
      <field name="active" eval="True"/>
      <field name="categ_id" ref="product.product_category_all"/>
      <field name="uom_id" ref="uom.product_uom_unit"/>
      <field name="uom_po_id" ref="uom.product_uom_unit"/>
      <field name="lst_price" eval="1.0"/>
      <field name="standard_price" eval="0.0"/>
      <field name="display_name">[GEN] Generic Product</field>
    </record>
  </data>
</odoo>
