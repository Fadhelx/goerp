<odoo>
  <data noupdate="1">
    <record id="account_generic_receivable" model="account.account">
      <field name="code">110000</field>
      <field name="name">Accounts Receivable</field>
      <field name="account_type">asset_receivable</field>
      <field name="internal_group">asset</field>
      <field name="reconcile">true</field>
    </record>
    <record id="account_generic_payable" model="account.account">
      <field name="code">210000</field>
      <field name="name">Accounts Payable</field>
      <field name="account_type">liability_payable</field>
      <field name="internal_group">liability</field>
      <field name="reconcile">true</field>
    </record>
    <record id="account_generic_bank" model="account.account">
      <field name="code">101000</field>
      <field name="name">Bank</field>
      <field name="account_type">asset_cash</field>
      <field name="internal_group">asset</field>
      <field name="reconcile">true</field>
    </record>
    <record id="account_generic_cash" model="account.account">
      <field name="code">102000</field>
      <field name="name">Cash</field>
      <field name="account_type">asset_cash</field>
      <field name="internal_group">asset</field>
      <field name="reconcile">true</field>
    </record>
    <record id="account_generic_income" model="account.account">
      <field name="code">400000</field>
      <field name="name">Income</field>
      <field name="account_type">income</field>
      <field name="internal_group">income</field>
      <field name="reconcile">false</field>
    </record>
    <record id="account_generic_expenses" model="account.account">
      <field name="code">500000</field>
      <field name="name">Expenses</field>
      <field name="account_type">expense</field>
      <field name="internal_group">expense</field>
      <field name="reconcile">false</field>
    </record>
    <record id="account_generic_liabilities" model="account.account">
      <field name="code">200000</field>
      <field name="name">Liabilities</field>
      <field name="account_type">liability_current</field>
      <field name="internal_group">liability</field>
      <field name="reconcile">false</field>
    </record>
    <record id="account_generic_equity" model="account.account">
      <field name="code">300000</field>
      <field name="name">Equity</field>
      <field name="account_type">equity</field>
      <field name="internal_group">equity</field>
      <field name="reconcile">false</field>
    </record>
    <record id="account_generic_current_year_earnings" model="account.account">
      <field name="code">399000</field>
      <field name="name">Current Year Earnings</field>
      <field name="account_type">equity_unaffected</field>
      <field name="internal_group">equity</field>
      <field name="reconcile">false</field>
    </record>

    <record id="journal_generic_sales" model="account.journal">
      <field name="code">SLS</field>
      <field name="name">Sales</field>
      <field name="type">sale</field>
      <field name="default_account_id" ref="account_generic_income"/>
      <field name="active">true</field>
      <field name="sequence">10</field>
    </record>
    <record id="journal_generic_purchases" model="account.journal">
      <field name="code">PUR</field>
      <field name="name">Purchases</field>
      <field name="type">purchase</field>
      <field name="default_account_id" ref="account_generic_expenses"/>
      <field name="active">true</field>
      <field name="sequence">20</field>
    </record>
    <record id="journal_generic_bank" model="account.journal">
      <field name="code">BNK</field>
      <field name="name">Bank</field>
      <field name="type">bank</field>
      <field name="default_account_id" ref="account_generic_bank"/>
      <field name="active">true</field>
      <field name="sequence">30</field>
    </record>
    <record id="journal_generic_cash" model="account.journal">
      <field name="code">CSH</field>
      <field name="name">Cash</field>
      <field name="type">cash</field>
      <field name="default_account_id" ref="account_generic_cash"/>
      <field name="active">true</field>
      <field name="sequence">40</field>
    </record>
    <record id="journal_generic_misc" model="account.journal">
      <field name="code">MSC</field>
      <field name="name">Miscellaneous</field>
      <field name="type">general</field>
      <field name="default_account_id" ref="account_generic_current_year_earnings"/>
      <field name="active">true</field>
      <field name="sequence">50</field>
    </record>
    <record id="journal_generic_tax_return" model="account.journal">
      <field name="code">TAX</field>
      <field name="name">Tax Return</field>
      <field name="type">general</field>
      <field name="default_account_id" ref="account_generic_liabilities"/>
      <field name="active">true</field>
      <field name="sequence">60</field>
    </record>
  </data>
</odoo>
