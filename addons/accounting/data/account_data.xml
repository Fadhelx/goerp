<odoo>
  <data noupdate="1">
    <record id="account_payment_term_immediate" model="account.payment.term">
      <field name="name">Immediate Payment</field>
      <field name="active" eval="True"/>
      <field name="note">Payment due immediately.</field>
    </record>
    <record id="account_payment_term_30days" model="account.payment.term">
      <field name="name">30 Days</field>
      <field name="active" eval="True"/>
      <field name="note">Payment due within 30 days.</field>
    </record>
    <record id="account_payment_term_30days_line" model="account.payment.term.line">
      <field name="payment_id" ref="account_payment_term_30days"/>
      <field name="value">balance</field>
      <field name="nb_days" eval="30"/>
    </record>
    <record id="account_payment_method_manual_in" model="account.payment.method">
      <field name="name">Manual Inbound</field>
      <field name="code">manual</field>
      <field name="payment_type">inbound</field>
    </record>
    <record id="account_payment_method_manual_out" model="account.payment.method">
      <field name="name">Manual Outbound</field>
      <field name="code">manual</field>
      <field name="payment_type">outbound</field>
    </record>
    <record id="account_tax_group_sales" model="account.tax.group">
      <field name="name">Sales Tax</field>
      <field name="sequence" eval="10"/>
    </record>
    <record id="account_tax_group_purchase" model="account.tax.group">
      <field name="name">Purchase Tax</field>
      <field name="sequence" eval="20"/>
    </record>
    <record id="account_tax_sale_15" model="account.tax">
      <field name="name">Sales Tax 15%</field>
      <field name="amount_type">percent</field>
      <field name="amount">15.0</field>
      <field name="type_tax_use">sale</field>
      <field name="tax_group_id" ref="account_tax_group_sales"/>
      <field name="active" eval="True"/>
    </record>
    <record id="account_tax_purchase_15" model="account.tax">
      <field name="name">Purchase Tax 15%</field>
      <field name="amount_type">percent</field>
      <field name="amount">15.0</field>
      <field name="type_tax_use">purchase</field>
      <field name="tax_group_id" ref="account_tax_group_purchase"/>
      <field name="active" eval="True"/>
    </record>
    <record id="account_cash_rounding_nearest" model="account.cash.rounding">
      <field name="name">Nearest Cent</field>
      <field name="rounding">0.01</field>
      <field name="strategy">add_invoice_line</field>
    </record>
  </data>
</odoo>
